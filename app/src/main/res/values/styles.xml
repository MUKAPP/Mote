<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Widget.Mote" parent="">
    </style>

    <!-- AI 消息卡片：中性 Card 色背景，无边框 -->
    <style name="Widget.Mote.MessageCard.Assistant" parent="Widget.Material3.CardView.Filled">
        <item name="cardCornerRadius">16dp</item>
        <item name="cardBackgroundColor">@color/mote_card</item>
        <item name="cardElevation">0dp</item>
        <item name="strokeWidth">0dp</item>
    </style>

    <!-- 用户消息卡片：Primary 透明度混合背景，无边框 -->
    <style name="Widget.Mote.MessageCard.User" parent="Widget.Material3.CardView.Filled">
        <item name="cardCornerRadius">16dp</item>
        <item name="cardBackgroundColor">@color/mote_user_message_card</item>
        <item name="cardElevation">0dp</item>
        <item name="strokeWidth">0dp</item>
    </style>

    <!-- Tonal 按钮：透明主题色背景 -->
    <style name="Widget.Mote.Button.Tonal" parent="Widget.Material3.Button.TonalButton">
        <item name="backgroundTint">@color/mote_primary_alpha_15</item>
        <item name="android:textColor">@color/mote_primary</item>
        <item name="iconTint">@color/mote_primary</item>
    </style>

    <!-- 圆角弹出菜单（长按消息、附件菜单等） -->
    <style name="Widget.Mote.PopupMenu" parent="Widget.Material3.PopupMenu">
        <item name="android:popupBackground">@drawable/popup_menu_background</item>
        <item name="android:popupElevation">3dp</item>
    </style>

    <!-- 消息长按菜单：自绘 PopupWindow 使用同一背景与窗口动画。 -->
    <style name="Widget.Mote.PopupMenu.Message" parent="Widget.Mote.PopupMenu">
        <item name="android:popupBackground">@drawable/popup_message_menu_background</item>
    </style>

    <style name="Animation.Mote.MessagePopupMenu" parent="">
        <item name="android:windowEnterAnimation">@anim/message_popup_menu_enter</item>
        <item name="android:windowExitAnimation">@anim/message_popup_menu_exit</item>
    </style>

    <!-- 思考强度选择 Chip -->
    <style name="Widget.Mote.Chip.Choice" parent="Widget.Material3.Chip.Filter">
        <item name="chipBackgroundColor">@color/mote_chip_background</item>
        <item name="android:textColor">@color/mote_chip_text</item>
        <item name="chipStrokeWidth">0dp</item>
        <item name="chipMinHeight">36dp</item>
        <item name="checkedIconVisible">false</item>
        <item name="chipCornerRadius">18dp</item>
        <item name="chipSurfaceColor">@android:color/transparent</item>
    </style>

    <!-- 设置页输入框 -->
    <style name="Widget.Mote.TextInputLayout" parent="Widget.Material3.TextInputLayout.FilledBox">
        <item name="boxBackgroundColor">@android:color/transparent</item>
        <item name="boxStrokeWidth">0dp</item>
        <item name="boxStrokeWidthFocused">0dp</item>
    </style>

    <style name="Widget.Mote.TextInputEditText" parent="Widget.Material3.TextInputEditText.FilledBox">
        <item name="android:background">@drawable/settings_field_background</item>
    </style>
    <!-- 输入框附件 Chip -->
    <style name="Widget.Mote.Chip.Attachment" parent="Widget.Material3.Chip.Assist">
        <item name="chipBackgroundColor">@color/mote_card</item>
        <item name="android:textColor">@color/mote_on_background_secondary</item>
        <item name="chipIconTint">@color/mote_on_background_secondary</item>
        <item name="closeIconTint">@color/mote_on_background_secondary</item>
        <item name="chipStrokeWidth">0dp</item>
        <item name="chipSurfaceColor">@android:color/transparent</item>
        <item name="rippleColor">@android:color/transparent</item>
        <item name="android:textSize">12sp</item>
        <item name="chipMinHeight">32dp</item>
    </style>

    <!-- 用户消息卡片附件 Chip -->
    <style name="Widget.Mote.Chip.Attachment.User" parent="Widget.Material3.Chip.Assist">
        <item name="chipBackgroundColor">@color/mote_background</item>
        <item name="android:textColor">@color/mote_on_background</item>
        <item name="chipIconTint">@color/mote_on_background_secondary</item>
        <item name="chipStrokeWidth">0dp</item>
        <item name="chipSurfaceColor">@android:color/transparent</item>
        <item name="rippleColor">@android:color/transparent</item>
        <item name="android:textSize">13sp</item>
        <item name="chipMinHeight">32dp</item>
    </style>
</resources>
