<resources>
    <style name="Base.Theme.Mote" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Primary -->
        <item name="colorPrimary">@color/mote_primary</item>
        <item name="colorOnPrimary">@color/mote_on_primary</item>
        <item name="colorPrimaryContainer">@color/mote_primary_container</item>
        <item name="colorOnPrimaryContainer">@color/mote_on_primary_container</item>

        <!-- Secondary = Primary（单主题色方案） -->
        <item name="colorSecondary">@color/mote_primary</item>
        <item name="colorOnSecondary">@color/mote_on_primary</item>
        <item name="colorSecondaryContainer">@color/mote_primary_container</item>
        <item name="colorOnSecondaryContainer">@color/mote_on_primary_container</item>

        <!-- Surface / Background -->
        <item name="colorSurface">@color/mote_background</item>
        <item name="colorOnSurface">@color/mote_on_background</item>
        <item name="colorSurfaceVariant">@color/mote_card</item>
        <item name="colorOnSurfaceVariant">@color/mote_on_background_secondary</item>
        <item name="colorSurfaceContainer">@color/mote_card</item>
        <item name="colorSurfaceContainerHigh">@color/mote_card_nested</item>
        <item name="colorSurfaceContainerLow">@color/mote_background</item>
        <item name="android:colorBackground">@color/mote_background</item>

        <!-- Outline -->
        <item name="colorOutline">@color/mote_outline</item>
        <item name="colorOutlineVariant">@color/mote_divider</item>

        <!-- Error -->
        <item name="colorError">@color/mote_error</item>
        <item name="colorOnError">@color/mote_on_error</item>

        <!-- System bars -->
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:windowLightNavigationBar">true</item>

        <!-- Dialog -->
        <item name="materialAlertDialogTheme">@style/ThemeOverlay.Mote.MaterialAlertDialog</item>
        <!-- 底部弹出面板 -->
        <item name="bottomSheetDialogTheme">@style/ThemeOverlay.Mote.BottomSheetDialog</item>

        <!-- 圆角弹出菜单 -->
        <item name="popupMenuStyle">@style/Widget.Mote.PopupMenu</item>
        <item name="android:popupMenuStyle">@style/Widget.Mote.PopupMenu</item>
    </style>

    <style name="Theme.Mote" parent="Base.Theme.Mote" />

    <style name="ThemeOverlay.Mote.MaterialAlertDialog" parent="ThemeOverlay.Material3.MaterialAlertDialog">
        <item name="colorSurface">@color/mote_background</item>
        <item name="colorSurfaceContainerHigh">@color/mote_background</item>
        <item name="colorSurfaceContainerLow">@color/mote_background</item>
        <item name="colorSurfaceContainer">@color/mote_background</item>
        <item name="android:colorBackground">@color/mote_background</item>
        <!-- 关闭高度色调叠加，保证对话框背景与页面一致 -->
        <item name="elevationOverlayEnabled">false</item>
        <item name="buttonBarPositiveButtonStyle">@style/Widget.Mote.Button.Dialog.Positive</item>
    </style>

    <!-- 底部弹出面板：页面背景色 + 顶部圆角，去除高度色调 -->
    <style name="ThemeOverlay.Mote.BottomSheetDialog" parent="ThemeOverlay.Material3.BottomSheetDialog">
        <item name="colorSurface">@color/mote_background</item>
        <item name="colorSurfaceContainerHigh">@color/mote_background</item>
        <item name="colorSurfaceContainerLow">@color/mote_background</item>
        <item name="colorSurfaceContainer">@color/mote_background</item>
        <item name="android:colorBackground">@color/mote_background</item>
        <item name="elevationOverlayEnabled">false</item>
        <item name="bottomSheetStyle">@style/Widget.Mote.BottomSheet</item>
        <item name="android:navigationBarColor">@color/mote_background</item>
        <item name="android:windowLightNavigationBar">@bool/mote_light_system_bars</item>
    </style>

    <style name="Widget.Mote.BottomSheet" parent="Widget.Material3.BottomSheet.Modal">
        <item name="backgroundTint">@color/mote_background</item>
        <item name="shapeAppearanceOverlay">@style/ShapeAppearanceOverlay.Mote.BottomSheet</item>
        <item name="elevationOverlayEnabled">false</item>
    </style>

    <style name="ShapeAppearanceOverlay.Mote.BottomSheet" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSizeTopLeft">24dp</item>
        <item name="cornerSizeTopRight">24dp</item>
        <item name="cornerSizeBottomLeft">0dp</item>
        <item name="cornerSizeBottomRight">0dp</item>
    </style>

    <!-- 对话框积极按钮：胶囊型主题色填充 -->
    <style name="Widget.Mote.Button.Dialog.Positive" parent="Widget.Material3.Button">
        <item name="backgroundTint">@color/mote_primary</item>
        <item name="android:textColor">@color/mote_on_primary</item>
        <item name="shapeAppearance">@style/ShapeAppearance.Mote.Capsule</item>
    </style>

    <style name="ShapeAppearance.Mote.Capsule" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">50%</item>
    </style>
</resources>
